# Revenue Operator — Environment Variables
# Copy this to .env.local and fill in your values.
# REQUIRED vars are marked. Others are optional or have defaults.

# ─── Supabase (REQUIRED) ───────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ─── App URLs (REQUIRED) ───────────────────────────────
NEXT_PUBLIC_APP_URL=https://recall-touch.com
APP_URL=https://recall-touch.com

# ─── Stripe Billing (REQUIRED) ─────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Price IDs — create these in your Stripe dashboard
STRIPE_PRICE_SOLO_MONTH=
STRIPE_PRICE_SOLO_YEAR=
STRIPE_PRICE_BUSINESS_MONTH=
STRIPE_PRICE_BUSINESS_YEAR=
STRIPE_PRICE_SCALE_MONTH=
STRIPE_PRICE_SCALE_YEAR=

# ─── Telnyx Telephony (REQUIRED for calls/SMS) ────────
TELNYX_API_KEY=
TELNYX_CONNECTION_ID=
TELNYX_MESSAGING_PROFILE_ID=
TELNYX_PUBLIC_KEY=

# ─── AI Voice (REQUIRED for voice agent) ───────────────
VOICE_SERVER_URL=
VOICE_SERVER_SECRET=
NEXT_PUBLIC_VOICE_SERVER_URL=
DEEPGRAM_API_KEY=
ANTHROPIC_API_KEY=

# ─── Email (REQUIRED for transactional email) ──────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@recall-touch.com

# ─── Auth & Security (REQUIRED) ────────────────────────
SESSION_SECRET=
ENCRYPTION_KEY=
CRON_SECRET=
WEBHOOK_SECRET=

# ─── Optional: Twilio (fallback telephony) ─────────────
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=
# TWILIO_MESSAGING_SERVICE_SID=

# ─── Optional: CRM Integrations ───────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# HUBSPOT_CLIENT_SECRET=
# SALESFORCE_WEBHOOK_SECRET=
# PIPEDRIVE_WEBHOOK_SECRET=
# ZOHO_WEBHOOK_SECRET=

# ─── Optional: Calendar ───────────────────────────────
# GOOGLE_CALENDAR_CLIENT_ID=
# GOOGLE_CALENDAR_CLIENT_SECRET=
# GOOGLE_CALENDAR_REDIRECT_URI=
# ZOOM_CLIENT_ID=
# ZOOM_CLIENT_SECRET=

# ─── Optional: Zapier Integration ─────────────────────
# ZAPIER_CLIENT_SECRET=

# ─── Optional: Slack/Teams Notifications ──────────────
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=

# ─── Optional: Analytics ──────────────────────────────
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=

# ─── Optional: Redis (rate limiting, caching) ────────
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ─── Admin ────────────────────────────────────────────
# ADMIN_EMAIL=
# ADMIN_SECRET=
# OPS_SESSION_SECRET=
