# Minimal local dev — copy to .env.local and fill. No Vercel/Stripe/cron required to run.
# Get Supabase values from: Project Settings > API (Supabase Dashboard).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Required to apply migrations (npm run db:migrate). Get from: Project Settings > Database > Connection string (URI).
# Use "Transaction" or "Session" pooler URI; replace [YOUR-PASSWORD] with your database password.
# DATABASE_URL=postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=

# Session (use any 32+ char secret locally)
SESSION_SECRET=

# App URL for local dev (prod: https://www.recall-touch.com)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional — natural voice (ElevenLabs). Without it, browser TTS is used.
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=

# Required by prod:gate and cron routes (use any string locally)
CRON_SECRET=

# Required by prod:gate (public record hashing; founder export auth)
PUBLIC_VIEW_SALT=
FOUNDER_EXPORT_KEY=

# Stripe — set in .env.local or Vercel; never commit real keys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Optional: Stripe Pricing Table embed ID
# NEXT_PUBLIC_STRIPE_PRICING_TABLE_ID=
# Solo $297/mo, $2970/yr
STRIPE_PRICE_SOLO_MONTH=price_1T5D5aRxGx0Txx0YleYGKicS
STRIPE_PRICE_SOLO_YEAR=price_1T5FEURxGx0Txx0YeUAbw7p8
# Growth $497/mo, $5000/yr
STRIPE_PRICE_GROWTH_MONTH=price_1T5FGlRxGx0Txx0Y5FqMTO01
STRIPE_PRICE_GROWTH_YEAR=price_1T5FHjRxGx0Txx0YhKPDDKv3
# Team $2400/mo, $19000/yr
STRIPE_PRICE_TEAM_MONTH=price_1T5FJQRxGx0Txx0YW7QmXRgB
STRIPE_PRICE_TEAM_YEAR=price_1T5FJuRxGx0Txx0YKgrySQ5p
# Optional: legacy single price (no longer used; use tier+interval)
# STRIPE_PRICE_ID=

# Admin dashboard (/admin) — only this email can access
# ADMIN_EMAIL=

# Resend — transactional/drip email (welcome, trial reminders, etc.)
# RESEND_API_KEY=
# EMAIL_FROM=Recall Touch <noreply@recall-touch.com>

# Vapi.ai — voice agent (private key for server, public key optional for client)
# VAPI_API_KEY=
# VAPI_PUBLIC_KEY=
# Required for Twilio inbound → Vapi: your Vapi phone number id (dashboard)
# VAPI_PHONE_NUMBER_ID=
# Demo page voice: assistant id for "Talk with voice" (create in Vapi dashboard)
# VAPI_DEMO_ASSISTANT_ID=

# Twilio — SMS send/receive
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=   (e.g. +1234567890) or TWILIO_MESSAGING_SERVICE_SID=MG...

# Google Calendar (optional)
# GOOGLE_CALENDAR_CLIENT_ID=
# GOOGLE_CALENDAR_CLIENT_SECRET=
# GOOGLE_CALENDAR_REDIRECT_URI=   (default: NEXT_PUBLIC_APP_URL + /api/integrations/google-calendar/callback)
