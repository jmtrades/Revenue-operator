# Minimal local dev — copy to .env.local and fill. No Vercel/Stripe/cron required to run.
# Get Supabase values from: Project Settings > API (Supabase Dashboard).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Session (use any 32+ char secret locally)
SESSION_SECRET=

# App URL for local dev
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Required by prod:gate and cron routes (use any string locally)
CRON_SECRET=

# Required by prod:gate (public record hashing; founder export auth)
PUBLIC_VIEW_SALT=
FOUNDER_EXPORT_KEY=

# Stripe — set in .env.local or Vercel; never commit real keys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Optional: Stripe Pricing Table embed ID
# NEXT_PUBLIC_STRIPE_PRICING_TABLE_ID=
# Solo $297/mo, $2970/yr
STRIPE_PRICE_SOLO_MONTH=price_1T5D5aRxGx0Txx0YleYGKicS
STRIPE_PRICE_SOLO_YEAR=price_1T5FEURxGx0Txx0YeUAbw7p8
# Growth $497/mo, $5000/yr
STRIPE_PRICE_GROWTH_MONTH=price_1T5FGlRxGx0Txx0Y5FqMTO01
STRIPE_PRICE_GROWTH_YEAR=price_1T5FHjRxGx0Txx0YhKPDDKv3
# Team $2400/mo, $19000/yr
STRIPE_PRICE_TEAM_MONTH=price_1T5FJQRxGx0Txx0YW7QmXRgB
STRIPE_PRICE_TEAM_YEAR=price_1T5FJuRxGx0Txx0YKgrySQ5p
# Optional: legacy single price (no longer used; use tier+interval)
# STRIPE_PRICE_ID=
