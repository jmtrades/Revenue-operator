# Everything runs on Supabase (database + auth). See docs/SUPABASE_SETUP.md.
# Copy to .env.local and fill. Get values from Supabase Dashboard → Project Settings → API.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: only needed to run migrations (npm run db:migrate). Or use Supabase CLI: supabase link && supabase db push.
# Project Settings → Database → Connection string (URI), Transaction pooler. Replace [YOUR-PASSWORD].
# DATABASE_URL=postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=

# Session — REQUIRED for sign-in/sign-up to work. Use a 32+ char random string.
# Must be set in Vercel (or your host) for production; otherwise users see "Sign-in isn't set up yet".
SESSION_SECRET=

# Core Application
APP_URL=                        # Full application URL (e.g., https://recall-touch.com)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Admin
ADMIN_API_TOKEN=                # Admin API authentication token

# Encryption
ENCRYPTION_KEY=                 # Data encryption key for sensitive fields

# Voice — Revenue Operator voice server (self-hosted TTS/STT). See services/voice-server/README.md.
# VOICE_SERVER_URL is required for voice calls. Set to your deployed voice server URL.
# In development, run the voice server locally at http://localhost:8100.

# Intelligence & Cron
CRON_SECRET=                    # Secret for authenticating cron job requests
INTELLIGENCE_LOOP_INTERVAL=     # Interval for intelligence loop (default: 4 hours)
DAILY_CALL_PLAN_TIME=           # Time for daily call plan (default: 7 AM UTC)

# Webhook Secrets (REQUIRED)
VOICE_WEBHOOK_SECRET=           # HMAC secret for voice webhook signature validation (REQUIRED)
WEBHOOK_SECRET=                 # General webhook signature secret
WEBHOOK_INBOX_SECRET=           # Inbox webhook secret

# Required by prod:gate (public record hashing; founder export auth)
PUBLIC_VIEW_SALT=
FOUNDER_EXPORT_KEY=

# Stripe — set in .env.local or Vercel; never commit real keys
STRIPE_SECRET_KEY=              # Stripe secret API key (REQUIRED for billing)
STRIPE_WEBHOOK_SECRET=          # Stripe webhook signing secret (REQUIRED for billing webhooks)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Optional: Stripe Pricing Table embed ID
# NEXT_PUBLIC_STRIPE_PRICING_TABLE_ID=
# Solo $297/mo, $2970/yr
STRIPE_PRICE_SOLO_MONTH=
STRIPE_PRICE_SOLO_YEAR=
# Business
STRIPE_PRICE_BUSINESS_MONTH=
STRIPE_PRICE_BUSINESS_YEAR=
# Scale
STRIPE_PRICE_SCALE_MONTH=
STRIPE_PRICE_SCALE_YEAR=
# Optional: legacy single price (no longer used; use tier+interval)
# STRIPE_PRICE_ID=

# Admin dashboard (/admin) — only this email can access
# ADMIN_EMAIL=

# Resend — transactional/drip email (welcome, trial reminders, etc.)
# RESEND_API_KEY=
# EMAIL_FROM=Recall Touch <noreply@recall-touch.com>

# Voice Provider — "recall" (self-hosted, default)
VOICE_PROVIDER=recall

# Self-hosted Recall Voice Server (FishSpeech TTS + Faster-Whisper STT)
VOICE_SERVER_URL=http://localhost:8100
DEFAULT_VOICE_ID=us-female-warm-receptionist

# Twilio — legacy fallback provider (optional if using Telnyx as primary)
TWILIO_ACCOUNT_SID=             # Twilio account SID (optional if using Telnyx)
TWILIO_AUTH_TOKEN=              # Twilio auth token (optional if using Telnyx)
# TWILIO_PROXY_NUMBER=+1234567890 (optional: use one shared number instead of purchasing per workspace)
# TWILIO_PHONE_NUMBER=            (optional: for SMS send; or use TWILIO_MESSAGING_SERVICE_SID=MG...)

# Telephony Provider Selection
TELEPHONY_PROVIDER=telnyx       # Set to "telnyx" (primary) or "twilio" (legacy fallback)

# Lead inbound webhook (Settings → Integrations): optional shared secret for POST /api/webhooks/lead-inbound (x-api-key header).
# LEAD_INBOUND_WEBHOOK_SECRET=

# Google (optional)
# GOOGLE_API_KEY=   (Google Cloud API key for Maps, Places, etc. Calendar uses OAuth below.)
# Google Calendar (OAuth)
# GOOGLE_CALENDAR_CLIENT_ID=
# GOOGLE_CALENDAR_CLIENT_SECRET=
# GOOGLE_CALENDAR_REDIRECT_URI=   (default: NEXT_PUBLIC_APP_URL + /api/integrations/google-calendar/callback)

# Telnyx — phone number provisioning, voice calls, SMS (primary provider)
TELNYX_API_KEY=                 # Telnyx API key for phone/voice provisioning
TELNYX_PUBLIC_KEY=              # Telnyx public key
TELNYX_CONNECTION_ID=           # Telnyx SIP connection ID for voice calls (REQUIRED)
TELNYX_MESSAGING_PROFILE_ID=    # Telnyx messaging profile ID for SMS (REQUIRED)
# TELNYX_VERIFY_PROFILE_ID=
# TELNYX_BILLING_GROUP_ID=
# TELNYX_BUNDLE_ID=
# TELNYX_REQUIREMENT_GROUP_ID=

# AI / LLM
ANTHROPIC_API_KEY=              # Claude API key for AI features
# OPENAI_API_KEY=

# Optional: voice synthesis and transcription
# DEEPGRAM_API_KEY=
# ELEVENLABS_API_KEY=

# Optional: demo mode
# DEMO_WORKSPACE_ID=
# ALLOW_DEMO_SEED=false

# Optional: PostHog analytics
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=

# Optional: Slack integration (OAuth)
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=

# Optional: Pipecat voice (alternative provider)
# PIPECAT_SERVER_URL=

# Optional: Redis for rate limiting (falls back to in-memory)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
