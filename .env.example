# Everything runs on Supabase (database + auth). See docs/SUPABASE_SETUP.md.
# Copy to .env.local and fill. Get values from Supabase Dashboard → Project Settings → API.

# ============================================================================
# Core App
# ============================================================================

# REQUIRED: Session secret for sign-in/sign-up. Use a 32+ char random string.
# Must be set in Vercel (or your host) for production
SESSION_SECRET=your_session_secret_here
# REQUIRED: Alternative/override for SESSION_SECRET
OPS_SESSION_SECRET=
# REQUIRED: Build ID for version tracking
BUILD_ID=
# Optional: Alternate app URL (used as fallback)
APP_URL=
# REQUIRED: Application public URL for OAuth callbacks, webhooks, links
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Optional: Webhook base URL (defaults to NEXT_PUBLIC_APP_URL)
WEBHOOK_BASE_URL=
# Optional: Alternate session encryption key
ENCRYPTION_KEY=
# Optional: Port PIN encryption (specific to port PIN feature)
PORT_PIN_ENCRYPTION_KEY=
# Optional: Feature flag for unsafe write operations (default: false)
DISABLE_UNSAFE_WRITE_GUARD=false
ENABLE_UNSAFE_WRITE_GUARD=false
# Optional: Founder/admin export key for authorized exports
FOUNDER_EXPORT_KEY=
# Optional: Doctrine enforcement (internal feature)
DOCTRINE_ENFORCED=0
# Optional: Economic settlement enabled (requires Stripe)
ECONOMIC_SETTLEMENT_ENABLED=true

# ============================================================================
# Authentication & Admin
# ============================================================================

# REQUIRED: Admin API token for protected admin endpoints
ADMIN_API_TOKEN=your_admin_api_token_here
# Optional: Admin email that can access /admin dashboard
ADMIN_EMAIL=admin@example.com
# Optional: Secret for dev simulation endpoints (development only)
DEV_SIM_SECRET=
# Optional: Operations dev magic link enabled (development only)
OPS_DEV_MAGIC_LINK=false
NEXT_PUBLIC_OPS_DEV_MAGIC_LINK=false
# Optional: Operations token for internal operations
OPS_TOKEN=

# ============================================================================
# Database (Supabase)
# ============================================================================

# REQUIRED: Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# REQUIRED: Supabase anonymous key (public, safe in browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
# REQUIRED: Supabase service role key (keep secret, server-side only)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# Optional: PostgreSQL connection string (for migrations via supabase CLI or npm run db:migrate)
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=

# ============================================================================
# Stripe Billing
# ============================================================================

# REQUIRED: Stripe secret API key (sk_live_... or sk_test_...)
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
# REQUIRED: Stripe webhook signing secret (whsec_...)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
# REQUIRED: Stripe publishable key (pk_live_... or pk_test_...)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
# Optional: Default tier price ID for billing
STRIPE_DEFAULT_PRICE_ID=price_your_default_price_id
# Optional: Legacy single price ID (no longer used)
STRIPE_PRICE_ID=
# Optional: Stripe Pricing Table embed ID
NEXT_PUBLIC_STRIPE_PRICING_TABLE_ID=

# ============================================================================
# Voice / Telephony (Telnyx)
# ============================================================================

# REQUIRED: Telnyx API key (v2 API)
TELNYX_API_KEY=your_telnyx_api_key_here
# REQUIRED: Telnyx public key (for signature verification)
TELNYX_PUBLIC_KEY=your_telnyx_public_key_here
# REQUIRED: Telnyx SIP connection ID for voice calls
TELNYX_CONNECTION_ID=your_telnyx_connection_id_here
# REQUIRED: Telnyx messaging profile ID for SMS
TELNYX_MESSAGING_PROFILE_ID=your_messaging_profile_id_here
# Optional: Telnyx phone number (for voice/SMS, defaults to workspace config)
TELNYX_PHONE_NUMBER=+12125551234
# Optional: Telnyx fallback phone number (if TELNYX_PHONE_NUMBER unavailable)
TELNYX_FALLBACK_NUMBER=
# Optional: Telnyx verify profile ID (for phone number verification)
TELNYX_VERIFY_PROFILE_ID=
# Optional: Telnyx billing group ID
TELNYX_BILLING_GROUP_ID=
# Optional: Telnyx bundle ID (for compliance)
TELNYX_BUNDLE_ID=
# Optional: Telnyx requirement group ID (for compliance)
TELNYX_REQUIREMENT_GROUP_ID=

# ============================================================================
# Voice / Telephony (Twilio - Fallback)
# ============================================================================

# Optional: Twilio account SID (only if using Twilio as fallback)
TWILIO_ACCOUNT_SID=
# Optional: Twilio auth token (only if using Twilio as fallback)
TWILIO_AUTH_TOKEN=
# Optional: Twilio phone number (for voice/SMS)
TWILIO_PHONE_NUMBER=
# Optional: Twilio messaging service SID (alternative to TWILIO_PHONE_NUMBER)
TWILIO_MESSAGING_SERVICE_SID=
# Optional: Twilio proxy number (shared number instead of per-workspace)
TWILIO_PROXY_NUMBER=
# Optional: Twilio verify service SID (for SMS verification)
TWILIO_VERIFY_SERVICE_SID=

# ============================================================================
# Voice Server
# ============================================================================

# REQUIRED: Voice server URL (self-hosted or external)
# Development: http://localhost:8100
# Production: https://your-voice-server.com
VOICE_SERVER_URL=http://localhost:8100
# Optional: Public voice server URL (if different from VOICE_SERVER_URL)
NEXT_PUBLIC_VOICE_SERVER_URL=
# Optional: Voice server secret for webhook authentication
VOICE_SERVER_SECRET=
# REQUIRED: Default voice ID for TTS (used if workspace doesn't have custom voice)
DEFAULT_VOICE_ID=us-female-warm-receptionist
# Optional: Demo voice ID (for demo workspace)
DEMO_VOICE_ID=
# REQUIRED: Voice provider selection (recall, telnyx, pipecat)
VOICE_PROVIDER=recall
# Optional: Fallback voice provider if primary unavailable
VOICE_FALLBACK_PROVIDER=
# Optional: Shadow mode for voice (copy calls to another provider for testing)
VOICE_SHADOW_MODE=false
# Optional: Pipecat server URL (alternative provider)
PIPECAT_SERVER_URL=

# ============================================================================
# AI / LLM
# ============================================================================

# REQUIRED: Claude/Anthropic API key
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Optional: OpenAI API key (for GPT models, transcript analysis)
OPENAI_API_KEY=your_openai_api_key_here
# Optional: Deepgram API key (for speech-to-text alternative)
DEEPGRAM_API_KEY=

# ============================================================================
# Email
# ============================================================================

# Optional: Email sending via Resend (transactional emails, welcome drips)
RESEND_API_KEY=
# Optional: Email "From" address (used in transactional emails)
EMAIL_FROM=Revenue Operator <noreply@recall-touch.com>
# Optional: Resend-specific "From" email (overrides EMAIL_FROM)
RESEND_FROM_EMAIL=noreply@recall-touch.com

# ============================================================================
# Zoom Integration
# ============================================================================

# Optional: Zoom OAuth client ID
ZOOM_CLIENT_ID=
# Optional: Zoom OAuth client secret
ZOOM_CLIENT_SECRET=
# Optional: Zoom webhook signing secret
ZOOM_WEBHOOK_SECRET=

# ============================================================================
# Google Integration
# ============================================================================

# Optional: Google Calendar OAuth client ID (via Google Cloud Console)
GOOGLE_CALENDAR_CLIENT_ID=
# Optional: Google Calendar OAuth client secret
GOOGLE_CALENDAR_CLIENT_SECRET=
# Optional: Google Calendar OAuth redirect URI (defaults to /api/integrations/google-calendar/callback)
GOOGLE_CALENDAR_REDIRECT_URI=
# Optional: Alternative Google OAuth client ID (fallback)
GOOGLE_CLIENT_ID=
# Optional: Alternative Google OAuth client secret
GOOGLE_CLIENT_SECRET=
# Optional: Google OAuth client ID (for compatibility)
GOOGLE_OAUTH_CLIENT_ID=
# Optional: Google OAuth client secret
GOOGLE_OAUTH_CLIENT_SECRET=

# ============================================================================
# Zapier Integration
# ============================================================================

# Optional: Zapier client secret (for webhook authentication)
ZAPIER_CLIENT_SECRET=

# ============================================================================
# CRM Integrations & Webhooks
# ============================================================================

# REQUIRED: Webhook secret for lead inbound endpoint (/api/webhooks/lead-inbound)
INBOUND_WEBHOOK_SECRET=
# Optional: Specific lead inbound webhook secret (overrides INBOUND_WEBHOOK_SECRET)
LEAD_INBOUND_WEBHOOK_SECRET=
# Optional: Generic CRM webhook secret (for custom CRM integrations)
CRM_WEBHOOK_SECRET=
# Optional: GoHighLevel webhook secret
GHL_WEBHOOK_SECRET=
# Optional: HubSpot webhook secret / client secret
HUBSPOT_CLIENT_SECRET=
# Optional: Pipedrive webhook secret
PIPEDRIVE_WEBHOOK_SECRET=
# Optional: Salesforce webhook secret
SALESFORCE_WEBHOOK_SECRET=
# Optional: Zoho CRM webhook secret
ZOHO_WEBHOOK_SECRET=
# Optional: Tool webhook secret
TOOL_WEBHOOK_SECRET=

# ============================================================================
# Cron / Scheduling
# ============================================================================

# REQUIRED: Secret for authenticating cron job requests (x-api-key header)
CRON_SECRET=your_cron_secret_here

# ============================================================================
# Feature Flags & Advanced
# ============================================================================

# Optional: AB test streaming mode (split or default)
AB_TEST_STREAMING=split
# Optional: Slack OAuth client ID
SLACK_CLIENT_ID=
# Optional: Slack OAuth client secret
SLACK_CLIENT_SECRET=
# Optional: Microsoft Entra/Azure AD client ID (for calendars, Teams)
MICROSOFT_CLIENT_ID=
# Optional: Microsoft Entra/Azure AD client secret
MICROSOFT_CLIENT_SECRET=
# Optional: Airtable base ID (for integrations)
AIRTABLE_BASE_ID=
# Optional: Airtable table name (defaults to "Contacts")
AIRTABLE_TABLE_NAME=Contacts
# Optional: Scenario ingest key (for AI ingest)
SCENARIO_INGEST_KEY=
# Optional: Demo workspace ID (for demo/testing)
DEMO_WORKSPACE_ID=
# Optional: Demo external reference
DEMO_EXTERNAL_REF=
# Optional: Public demo external reference
NEXT_PUBLIC_DEMO_EXTERNAL_REF=
# Optional: Allow demo seed data in production (default: false)
ALLOW_DEMO_SEED=false
# Optional: Telephony provider selection (telnyx, twilio, or auto-detect)
TELEPHONY_PROVIDER=telnyx
# Optional: Fallback telephony provider if primary unavailable
TELEPHONY_FALLBACK_PROVIDER=

# ============================================================================
# Analytics & Monitoring
# ============================================================================

# Optional: PostHog API key (analytics)
NEXT_PUBLIC_POSTHOG_KEY=
# Optional: PostHog host (defaults to https://app.posthog.com)
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ============================================================================
# Cache & Rate Limiting
# ============================================================================

# Optional: Upstash Redis URL (for rate limiting, caching)
UPSTASH_REDIS_REST_URL=
# Optional: Upstash Redis token
UPSTASH_REDIS_REST_TOKEN=

# ============================================================================
# Runtime & Deployment (Auto-Set by Vercel/Deployment Platform)
# ============================================================================

# Automatically set by Next.js build/runtime
NEXT_RUNTIME=nodejs
# Automatically set by Vercel
NODE_ENV=development
# Automatically set by Vercel (production or preview)
VERCEL_ENV=
# Automatically set by Vercel
VERCEL_URL=
# Automatically set by Vercel (git commit SHA)
VERCEL_GIT_COMMIT_SHA=
# Automatically set by Vercel (git branch ref)
VERCEL_GIT_COMMIT_REF=
# Automatically set by build system
NEXT_PUBLIC_BUILD_ID=
