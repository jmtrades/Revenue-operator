# Voice Synthesis Server Configuration
# Copy this to .env and customize for your environment

# ============================================================================
# Server Configuration
# ============================================================================

# Server host and port
HOST=0.0.0.0
PORT=8100

# Logging level: debug, info, warning, error
LOG_LEVEL=info

# ============================================================================
# LLM Integration
# ============================================================================

# Endpoint for getting LLM responses during conversations
# This is called to generate assistant responses
LLM_ENDPOINT=http://localhost:3000/api/agent/respond

# LLM API key (if required by your LLM endpoint)
LLM_API_KEY=

# ============================================================================
# Model Configuration
# ============================================================================

# TTS (Text-to-Speech) model
# Options: fishspeech-1.5, tacotron2, glow-tts
TTS_MODEL=fishspeech-1.5

# STT (Speech-to-Text) model
# Options: whisper-tiny, whisper-base, whisper-small, whisper-medium, whisper-large
STT_MODEL=whisper-base

# Model cache directory
MODEL_CACHE_DIR=/app/.cache

# ============================================================================
# Audio Processing
# ============================================================================

# Sample rate in Hz
SAMPLE_RATE=16000

# Audio chunk size in samples (for streaming)
AUDIO_CHUNK_SIZE=4096

# Default silence timeout in milliseconds
DEFAULT_SILENCE_TIMEOUT_MS=1500

# ============================================================================
# Voice Cloning
# ============================================================================

# Enable voice cloning feature
VOICE_CLONING_ENABLED=true

# Voice cloning model
VOICE_CLONING_MODEL=speaker-encoder

# ============================================================================
# Conversation Features
# ============================================================================

# Enable backchanneling (natural responses like "mm-hmm", "I see")
BACKCHANNEL_ENABLED=true

# Minimum interval between backchannels (seconds)
BACKCHANNEL_INTERVAL=2.0

# Enable tool calling support
TOOL_CALLING_ENABLED=true

# Session cleanup interval (seconds)
SESSION_CLEANUP_INTERVAL=600

# ============================================================================
# Performance & Optimization
# ============================================================================

# Number of TTS worker threads
TTS_WORKERS=2

# Number of STT worker threads
STT_WORKERS=2

# Maximum concurrent conversations
MAX_CONCURRENT_CONVERSATIONS=10

# TTS chunk size in milliseconds (smaller = lower latency, higher CPU)
TTS_CHUNK_SIZE_MS=50

# ============================================================================
# Security & Rate Limiting
# ============================================================================

# Enable rate limiting
RATE_LIMITING_ENABLED=true

# Requests per second (per IP)
RATE_LIMIT_RPS=10

# Request timeout in seconds
REQUEST_TIMEOUT=30

# ============================================================================
# Database (Optional - for session persistence)
# ============================================================================

# Database URL (if using PostgreSQL for sessions)
# DATABASE_URL=postgresql://user:password@localhost:5432/voice_sessions

# ============================================================================
# Monitoring & Observability
# ============================================================================

# Datadog API key (optional)
DATADOG_API_KEY=

# Sentry DSN for error tracking (optional)
SENTRY_DSN=

# ============================================================================
# Development (Do NOT use in production)
# ============================================================================

# Enable CORS for all origins (development only)
CORS_ENABLED=true
CORS_ORIGINS=*

# Enable detailed debug logging
DEBUG=false

# Disable SSL verification (development only)
VERIFY_SSL=true
